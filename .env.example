# Docker Compose project/container name prefix.
COMPOSE_PROJECT_NAME=construction-tracker

# MySQL database name used by backend TypeORM.
DB_NAME=construction_tracker

# MySQL application user.
DB_USER=construction_user

# MySQL application user password.
DB_PASSWORD=replace-with-a-strong-password

# MySQL root password for initialization and administration.
DB_ROOT_PASSWORD=replace-with-a-strong-root-password

# JWT signing secret. Use a long random value in production.
JWT_SECRET=replace-with-a-long-random-secret

# Host port exposed by the frontend Nginx container.
FRONTEND_PORT=18701

# Host port exposed by the backend container.
BACKEND_PORT=19201
